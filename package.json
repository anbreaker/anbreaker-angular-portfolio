{
  "commitlint": {
    "rules": {
      "description": "max 50 chars, imperative, no period",
      "format": "<type>(<scope>): <description>",
      "scope": "optional, kebab-case (e.g. auth, store, routing)",
      "types": "feat | fix | docs | style | refactor | test | chore | perf | ci | build | revert"
    }
  },
  "dependencies": {
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.0",
    "@jsverse/transloco": "^8.2.1",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4",
    "resend": "^6.12.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@types/node": "^25.6.0",
    "@vercel/node": "^5.7.13",
    "@vitest/ui": "^4.1.0",
    "angular-eslint": "^21.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "jsdom": "^29.1.0",
    "json-server": "^1.0.0-beta.3",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.19.0",
    "npm": ">=10.9.3"
  },
  "name": "anbreaker-angular-portfolio",
  "packageManager": "npm@10.9.3",
  "private": true,
  "scripts": {
    "build": "vite build",
    "commit:validate": "node -e \"const msg = process.argv[1]; const ok = /^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\\(.+\\))?: .{1,50}/.test(msg); process.exit(ok ? 0 : 1);\" --",
    "dev": "vite --mode dev --open",
    "dev:api": "concurrently \"npm run json-server\" \"npm run dev\"",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\" \"*.json\"",
    "json-server": "json-server --watch server/db.json --port 3000",
    "lint": "eslint \"src/**/*.{ts,js}\" && eslint \"*.json\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix && eslint \"*.json\" --fix",
    "lint:prod": "NODE_ENV=production eslint \"src/**/*.{ts,js}\" && NODE_ENV=production eslint \"*.json\"",
    "ng": "ng",
    "preview": "vite preview",
    "start": "vite --mode dev --open",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "watch": "vite build --watch"
  },
  "type": "module",
  "version": "0.0.0"
}
