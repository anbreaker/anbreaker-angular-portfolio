{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": false,
    "packageManager": "npm",
    "schematicCollections": ["angular-eslint"]
  },
  "newProjectRoot": "projects",
  "projects": {
    "anbreaker-angular-portfolio": {
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "configurations": {
            "demo": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.demo.ts"
                }
              ],
              "outputHashing": "all"
            },
            "dev": {
              "extractLicenses": false,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev.ts"
                }
              ],
              "optimization": false,
              "sourceMap": true
            },
            "development": {
              "extractLicenses": false,
              "optimization": false,
              "sourceMap": true
            },
            "preproduction": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.preproduction.ts"
                }
              ],
              "outputHashing": "all"
            },
            "production": {
              "budgets": [
                {
                  "maximumError": "1MB",
                  "maximumWarning": "500kB",
                  "type": "initial"
                },
                {
                  "maximumError": "8kB",
                  "maximumWarning": "4kB",
                  "type": "anyComponentStyle"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all",
              "subresourceIntegrity": true
            },
            "test": {
              "extractLicenses": false,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.test.ts"
                }
              ],
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production",
          "options": {
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets"
              }
            ],
            "browser": "src/main.ts",
            "inlineStyleLanguage": "scss",
            "outputPath": "www",
            "stylePreprocessorOptions": {
              "includePaths": ["src/styles"]
            },
            "styles": ["src/styles/styles.scss"],
            "tsConfig": "tsconfig.app.json"
          }
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "dev": {
              "buildTarget": "anbreaker-angular-portfolio:build:dev"
            },
            "development": {
              "buildTarget": "anbreaker-angular-portfolio:build:development"
            },
            "production": {
              "buildTarget": "anbreaker-angular-portfolio:build:production"
            }
          },
          "defaultConfiguration": "development"
        }
      },
      "prefix": "app",
      "projectType": "application",
      "root": "",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush",
          "inlineStyle": false,
          "inlineTemplate": false,
          "standalone": true,
          "style": "scss",
          "type": "component"
        }
      },
      "sourceRoot": "src"
    }
  },
  "version": 1
}
